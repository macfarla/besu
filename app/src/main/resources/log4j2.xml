<?xml version="1.0" encoding="UTF-8"?>
<Configuration level="WARN" xmlns:xi="http://www.w3.org/2001/XInclude">
    <xi:include href="log4j2-besu-properties.xml"/>

    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout
                disableAnsi="${sys:besu.disableAnsi:-false}"
                noConsoleNoAnsi="${sys:besu.disableAnsi:-false}"
                pattern="%style{%d{yyyy-MM-dd HH:mm:ss.SSSZZZ}}{DIM}%style{ | }{DIM}%style{%t}{DIM}%style{ | }{DIM}%highlight{%-5level}{TRACE=normal}%style{ | }{DIM}%style{%c{1}}{DIM}%style{ | }{DIM}%highlight{%msgc%n%throwable}{TRACE=normal}" />
        </Console>
        <xi:include href="log4j2-besu-splunk-appender.xml"/>
    </Appenders>

    <xi:include href="log4j2-besu-loggers.xml"/>
</Configuration>
